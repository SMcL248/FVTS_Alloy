sig oCloud {
	dms : one DMS,
	var nodes : set Node
}
	
sig DMS {
	cloud : one oCloud,
	var requests : set Request
}

one sig SMO {
	var responses: set Request->Response
}

sig Node {
	var deployment : set NF
}

sig NF {}

sig Request {
	target : one oCloud,
	payload : one NF,
	var underlying_error : lone Response,
	var processed : lone Response
}

enum Response {
	SUCCESS, 
	ERROR
}


//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	deployment' = deployment 
	nodes' = nodes
	requests' = requests
	responses' = responses
	underlying_error' = underlying_error
	processed' = processed
}

pred act {
	some r : Request, c : oCloud | initiate_deployment[r] or finish_deployment[r,c] or sim_error[r,c] or response[r, c]
}

// If a request is present, we assume that all precondtions are met and the request is sent to the appropriate DMS.
pred initiate_deployment [r : Request] {
	
	historically r not in r.target.dms.requests and some r.target.nodes//guard

	requests' = requests + r.target.dms->r

	deployment' = deployment 	
	nodes' = nodes
	responses' = responses
	underlying_error' = underlying_error
	processed' = processed
}

// Simulate some configuation error
pred sim_error [r : Request, c : oCloud] {

	r in c.dms.requests and no r.underlying_error//guard

	underlying_error' = underlying_error + r->SUCCESS or underlying_error' = underlying_error + r->ERROR

	deployment' = deployment 
	nodes' = nodes
	requests' = requests
	responses' = responses
	processed' = processed
}

// Deploy NF.
pred finish_deployment [r : Request, c : oCloud] {

	r in c.dms.requests and some r.underlying_error//guard

	(r.underlying_error = SUCCESS) implies (
		some node : Node | node in c.nodes and deployment' = deployment + node->r.payload and processed' = processed + r->SUCCESS
	)else(
		deployment' = deployment and processed' = processed+ r->ERROR
	)	

	requests' = requests
	responses' = responses
	nodes' = nodes
	underlying_error' = underlying_error
}

//Send a response to the SMO
pred response [r : Request, c : oCloud] {

	r in c.dms.requests and r.processed = SUCCESS//guard

	requests' = requests - c.dms->r
	responses' = responses + SMO->r->r.processed
	processed' = processed - r->r.processed
	underlying_error' = underlying_error - r->r.underlying_error

	nodes' = nodes
	deployment' = deployment 
	
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact act_or_stutter {
	always (stutter or act)
}

fact disj_NF {
//	all disj a,b : Request | a.payload != b.payload
	all r : Request | r.payload not in Node.deployment
}

fact init {
	all c : oCloud | some c.nodes
	all node : Node | no node.deployment
	all r : Request |  no r.underlying_error and no r.processed
	no SMO.responses
	all d : DMS | no d.requests
}

fact unique_cloud_properties {
	all disj a,b : oCloud | a.dms != b.dms
}

fact link_manageresources_with_correct_cloud {
	all d : DMS, c : oCloud | d.cloud = c <=> c.dms = d
}

// force all requests to eventual enter and leave the requests relation.
fact fairness{
	(all r : Request | eventually (before r in DMS.requests and r not in DMS.requests))
//	Node in oCloud.nodes	
}


//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// As the sequence describes no exceptions, we can assume that sent requests imply eventual success. 
assert preconditions_imply_success {
	always (all r : Request | r in DMS.requests implies eventually r->SUCCESS in SMO.responses)
}

assert added_nf_implies_successful_request {
	always (all nf : NF | (before nf not in Node.deployment and nf in Node.deployment) implies eventually some r : Request | r.payload = nf and r->SUCCESS in SMO.responses)
}

assert processed_request_implies_response {
	always (all r : Request | before r in DMS.requests and r not in DMS.requests implies (r->ERROR in SMO.responses or r->SUCCESS in SMO.responses))
}

assert response_implies_added_node {
	always (all r : Request | (r->SUCCESS in SMO.responses) implies (once r.payload not in Node.deployment) and r.payload in Node.deployment)
}

assert all_sent_response_eventually_processed {
	always (some r : Request | r in DMS.requests implies eventually some r.processed)
}

assert deployment_implies_error_message {
	always (all r : Request | r.underlying_error = ERROR implies eventually r->ERROR in SMO.responses)
}

//liveness
assert unsuccessful_deployment_implies_never_deployed {
	always (all nf : NF | once (some r : Request | r.payload = nf and r->ERROR in SMO.responses) => nf not in Node.deployment)
}

//liveness
assert NF_deployed_twice_allowed {
	always (all disj a,b : Request | a.payload = b.payload => eventually lone {r : Request | r in (a+b) and (r->SUCCESS in SMO.responses)})
}

//liveness
assert NF_not_in_two_locations {
	always all disj a,b : Node | no (a.deployment & b.deployment)
}

//liveness	
assert hardware_can_host_multiple_NFs {
	always (all node : Node | lone {nf : NF | nf in node.deployment})
}

assert successful_process_implies_successful_response {
	always (all r : Request | r.processed = SUCCESS implies eventually r->SUCCESS in SMO.responses)
}

