//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// (1) Safety
assert failure_implies_clean {
	always (all s : Slice | s->ERROR in SMO.response implies no s.ids)
}

// (2) Safety
assert available_and_used_disjoint {
	always (all c : oCloud, s : Slice | no c.available & {id : VLAN_ID | c->id in s.ids and id in c.deployed.trunk})
}

// (3) Safety
assert success_implies_deployment {
	always (all s : Slice | once (s->OK in SMO.response) implies s.nfs in oCloud.deployed)
}

// (4) Liveness
assert id_available_but_also_applied {
	always (all c : oCloud | no (c.available & c.deployed.trunk))
}

// (5) livness - success can happen
assert success{
	always (all s : Slice | s->OK not in SMO.response)
}

// (6) liveness - failure may occur
assert failure {
	always (all s : Slice | s->ERROR not in SMO.response)
}

// (7) liveness
assert failure_may_have_NF_instatitated {
	always (all s : Slice | s->ERROR in SMO.response implies all nf : NF | nf in s.nfs and nf not in oCloud.deployed)
}

// (8) liveness
assert multiple_clouds {
	always (all disj a,b : NF | some s : Slice | a in s.nfs and b in s.nfs and s->OK in SMO.response implies some c : oCloud | a in c.deployed and b in c.deployed)
}

