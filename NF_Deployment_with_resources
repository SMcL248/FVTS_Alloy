sig oCloud {
	dms : one DMS,
	var nodes : set Node// Set of deployed worker nodes
}
	
sig DMS {
	cloud : one oCloud,
	var requests : set Request // Set of received instantiation requests
}

one sig SMO {
	var responses: set Request->Response// Set of request responses
}

sig Node {
	var deployment : set NF// Set of NFs instantiatied on this machine
}

sig NF {}

sig Request {
	target : one oCloud, // O-Cloud for deployment
	payload : one NF, // NF to deploy
	var underlying_error : lone Response, //Does some non-descipt error occur?
	var processed : lone Response,// Final response to SMO
	required_resources : set Resource
}

sig Resource {
	var associated_nf : lone NF
}

enum Response {
	SUCCESS, 
	ERROR
}


//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	deployment' = deployment 
	nodes' = nodes
	requests' = requests
	responses' = responses
	underlying_error' = underlying_error
	processed' = processed
	associated_nf' = associated_nf
}

pred act {
	some r : Request, c : oCloud | initiate_deployment[r] or finish_deployment[r,c] or sim_error[r,c] or response[r, c] or allocate_resource[r,c] or success[r,c]
}

// If a request is present, we assume that all precondtions are met and the request is sent to the appropriate DMS.
pred initiate_deployment [r : Request] {
	
	historically r not in r.target.dms.requests and some r.target.nodes//guard

	requests' = requests + r.target.dms->r

	deployment' = deployment 	
	nodes' = nodes
	responses' = responses
	underlying_error' = underlying_error
	processed' = processed
	associated_nf' = associated_nf
}

// Simulate some configuation error
pred sim_error [r : Request, c : oCloud] {

	r in c.dms.requests and no r.underlying_error//guard

        underlying_error' = underlying_error + r->ERROR

	deployment' = deployment 
	nodes' = nodes
	requests' = requests
	responses' = responses
	processed' = processed
	associated_nf' = associated_nf
}

// allocate required resource
pred allocate_resource [r : Request, c : oCloud] {

	r in c.dms.requests and r.required_resources != {resource : Resource | resource.associated_nf = r.payload} and no r.underlying_error//guard

	some resource : Resource | (resource in r.required_resources and no resource.associated_nf) and
		associated_nf' = associated_nf + resource->r.payload

	deployment' = deployment 
	nodes' = nodes
	requests' = requests
	responses' = responses
	underlying_error' = underlying_error
	processed' = processed

}

// all resources allocated without failure
pred success [r: Request, c : oCloud] {

	r in c.dms.requests and r.required_resources = {resource : Resource | resource.associated_nf = r.payload} and no r.underlying_error//guard

	 underlying_error' = underlying_error + r->SUCCESS

	deployment' = deployment 
	nodes' = nodes
	requests' = requests
	responses' = responses
	processed' = processed
	associated_nf' = associated_nf
}

// Assuming no underlying errors occur, finish deployment
pred finish_deployment [r : Request, c : oCloud] {

	r in c.dms.requests and some r.underlying_error//guard

	(r.underlying_error = SUCCESS) implies (
		some node : Node | node in c.nodes and deployment' = deployment + node->r.payload and processed' = processed + r->SUCCESS
	)else(
		deployment' = deployment and processed' = processed+ r->ERROR
	)	

	requests' = requests
	responses' = responses
	nodes' = nodes
	underlying_error' = underlying_error
	associated_nf' = associated_nf
}

//Send a response to the SMO
pred response [r : Request, c : oCloud] {

	r in c.dms.requests and r.processed = SUCCESS//guard

	requests' = requests - c.dms->r
	responses' = responses + SMO->r->r.processed
	processed' = processed - r->r.processed
	underlying_error' = underlying_error - r->r.underlying_error

	nodes' = nodes
	deployment' = deployment 
	associated_nf' = associated_nf
	
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact act_or_stutter {
	always (stutter or act)
}

fact init {
	all disj a,b :Request | no (a.required_resources + b.required_resources)
	all c : oCloud | some c.nodes
	some Request
	all node : Node | no node.deployment
	all r : Request |  no r.underlying_error and no r.processed and r.payload not in Node.deployment and some r.required_resources
	no SMO.responses
	all d : DMS | no d.requests
	all r : Resource | no r.associated_nf
}

fact unique_cloud_properties {
	all disj a,b : oCloud | a.dms != b.dms
}

fact link_manageresources_with_correct_cloud {
	all d : DMS, c : oCloud | d.cloud = c <=> c.dms = d
}

// forces system progression
fact fairness{
//	eventually (all r : Request | once (before r in DMS.requests and r not in DMS.requests))
	eventually (all r : Request | some r.processed)
}

