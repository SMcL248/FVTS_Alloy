sig oCloud {
	ims : one IMS,
	var nodes : set oCloudNode
}

enum Status {
	SUCCESS,
	FAILED
}

sig IMS {
	cloud : one oCloud,
	var config_request : set oCloudNode->oCloud
}

one sig SMO {}

sig oCloudNode {
	var boot : lone Status
}

one sig CloudInstaller{
	var inbox : set oCloudNode->oCloud
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	nodes' = nodes
	inbox' = inbox
	config_request' = config_request
	boot' = boot
}

pred act {
	some node : oCloudNode, c : oCloud | expansion_request[node, c]  or send_config_request[node,c] or process_config_request[node, c] or boot[node, c]
}

// simulates the decision  of an operator to hardware scale a given O-Cloud
pred expansion_request [node : oCloudNode, c : oCloud]{
	
	node not in c.nodes//guard

	inbox' = inbox + CloudInstaller->node->c

	nodes' = nodes
	config_request' = config_request
	boot' = boot
}

// simulates the IMS receiving word of the hardware scale.
pred send_config_request [node : oCloudNode, c : oCloud] {
	
	node->c in CloudInstaller.inbox //guard
	
	config_request' = config_request + c.ims->node->c

	nodes' = nodes
	inbox' = inbox
	boot' = boot
}

// IMS waits for notification of successful boot
pred process_config_request [node : oCloudNode, c : oCloud] {
	
	node->c in c.ims.config_request and some node.boot//guard

	(node.boot = SUCCESS) implies(
		nodes' = nodes + c->node and
		config_request' = config_request - c.ims->node->c
	)else(
		nodes' = nodes and
		config_request' = config_request
	)

	inbox' = inbox
	boot' = boot
}

// simulate node boot success or failure
pred boot [node : oCloudNode, c : oCloud] {

	node->c in c.ims.config_request and no node.boot//guard 

	boot' = boot + node->FAILED or boot' = boot + node->SUCCESS

	inbox' = inbox
	nodes' = nodes
	config_request' = config_request
}

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact act_or_stutter {
	always (stutter or act)
}

fact init {
	all i : CloudInstaller | no i.inbox
	all ims : IMS | no ims.config_request 
	all c : oCloud | no c.nodes
	all node : oCloudNode | no node.boot
}
	
fact unique_cloud_properties {
	all disj a,b : oCloud | a.ims != b.ims
}

fact link_managers_with_correct_cloud {
	all i : IMS, c : oCloud | i.cloud = c <=> c.ims = i
}

fact fairness {
	eventually(all n : oCloudNode | once (some o: oCloud | (before n->o in IMS.config_request and n->o not in IMS.config_request)))
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// (1) Liveness (Violated) - we expect a counter-example showing that boot failure does not prevent the scale request from completing.
// No counterexample given => liveness property unsatisfied.
assert error_prevents_completion {
	always (all n : oCloudNode | (some ims : IMS, c : oCloud | (FAILED in n.boot) implies (n->c in ims.config_request))) //failed boot never allows request to complete
}

// (2) Liveness (Violated) (with fairness) - no counter example, that is, restricting trace such that all requests complete, means no error can occur.
// Ensure that 'fairness' fact is active. This forces all sent requests to eventually complete.
// We want to show that there exists a trace in which one of the completed requests corresponds with a failed scale, i.e. failure does not impede request completion.
// As this produces no counterexample, there exists no trace in which a failed request leaves the IMS config inbox. => liveness property not satisfied.
assert failure {
	always (all node : oCloudNode | FAILED not in node.boot)
}

// (3) Liveness (Violated) - should return a counterexample. That is, no Node that has failed to boot exists in Deployed nodes.
// (uncomment to enforce)
fact error_in_deployment {
//	eventually (some n : oCloudNode, c : oCloud | FAILED in n.boot and (before n->c in c.ims.config_request and n->c not in c.ims.config_request))//failure and request completion
}

// (4) Liveness (Satisfied) - we expect counter example where more than one Node exists in an O-Cloud.
assert multiple_nodes {
	always (all o : oCloud | lone {node : oCloudNode | node in o.nodes})
}

// (5) Liveness (Satisfied) -  we expect counter example where a Node is shared across multiple O-Cloud instances.
assert shared_nodes {
	always (all disj a,b : oCloud | no (a.nodes & b.nodes))
}

// (6) Safety (Validated) - Node only boots due to on-going hardware scale attempt
assert boot_implies_request {
	always (all node : oCloudNode | (before no node.boot and some node.boot) implies some c : oCloud | node->c in c.ims.config_request)
}

// (7) Safety (Validated) - Node in deployment implies successful boot
assert deployment_implies_success_boot {
	always (all n : oCloudNode | (n in oCloud.nodes) implies (SUCCESS in n.boot))
}

// (8) Safety (Validated) - with fairness, successful boot implies eventual deployment
assert success_boot_implies_node_deployment {
	always (all n : oCloudNode | (n.boot = SUCCESS) implies eventually n in oCloud.nodes)
}

// (9) Safety (Validated) - If a configuration request is complete, the node must be in deployment.
assert process_request_implies_deployment {
	always(all node : oCloudNode, c :oCloud | (before node->c in c.ims.config_request and node->c not in c.ims.config_request) implies node in c.nodes) // request procssed => node in deployment
}

// (10) Safey (Validated) - If IMS recieves config request, such a config plan must exist in the installer operator
assert ims_request_implies_operator_request {
	always (all node : oCloudNode, c : oCloud | node->c in IMS.config_request implies node->c in CloudInstaller.inbox)
}

