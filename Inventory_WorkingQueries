// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~STANDARD DATA TYPES~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// NOTE : Fix POST method for creating new subscriptions

// Abstract response type to allow for various payloads
abstract sig Response {}

abstract sig Id {}

one sig Null extends Id {}

sig Identifier extends Id {}

sig Query {
	body : HTTP -> ResponseType -> Id,
	extension : Resource->Id
}

enum HTTP {
	GET,
	POST,
	PATCH,
	DELETE,
	PUT
}

enum ResponseCode {
	_200_OK,
	_201_CREATED,
	_204_DELETED,
	_400_BAD_REQUEST,
	_401_UNAUTHORIZED,
	_403_FORBIDDEN,
	_404_NOT_FOUND,
	_405_METHOD_NOT_ALLOWED,
	_413_PAYLOAD_TOO_LARGE,
	_414_URI_TOO_LONG,
	_422_UNPROCESSABLE_ENTITY,
	_429_TOO_MANY_REQUESTS,
	_500_INTERNAL_SERVER_ERROR,
	_503_SERVICE_UNAVAILABLE,
	_504_GATEWAY_TIMEOUT
}

sig ProblemDetails extends Response {
	status : one ResponseCode
}

one sig ValidQueries {
	supported : set Query
}

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~RELEVANT ENUMERATED VALUES~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

enum ClearingType {
	automatic,
	manual
}

enum ManagementInterfaceId {
	O2IMS
}

enum ResourceKind {
	UNDEFINED_KIND,
	PHYSICAL,
	LOGICAL
}

enum ResourceClass {
	UNDEFINED_CLASS,
	COMPUTE,
	NETWORKING,
	STORAGE
}

enum AlarmChangeType{
	added,
	deleted,
	modified
}

enum ResponseType {
	Type,
	Resource,
	Pool,
	oCloud,
	AlarmDic,
//	PerformanceDictionary,
	DeploymentManager,
	InventorySubscription
}

	
// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~INVENTORY DATA TYPES~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

sig ResourceTypeInfo extends Response{
	resourceTypeId : one Identifier,
	resourceKind : one ResourceKind,
	resourceClass : one ResourceClass,
}

sig ResourcePoolInfo extends Response{
	resourcePoolId : one Identifier,
}

sig ResourceInfo extends Response {
	resourceId : one Identifier,
	resourcePoolId : one Identifier,
	resourceTypeId : one Identifier,
	elements : set ResourceInfo
}

sig DeploymentManagerInfo extends Response {
	deploymentManagerId : one Identifier,
	oCloudid : one Identifier
}

one sig OCloudInfo extends Response {
	oCloud : one Identifier,
	globalcloudId : one Identifier
}

sig InventorySubscriptionInfo extends Response{
	subscriptionId : one Identifier,
	var consumerSubscriptionId : lone Identifier
}

sig AlarmDictionary extends Response{
	alarmDictionaryId : one Identifier,
	managementInterfaceId : one ManagementInterfaceId,
	alarmDefinition : set AlarmDefinition,
	probableCauses : set ProbableCause
}

sig AlarmDefinition extends Response {
	alarmChangeType : one AlarmChangeType,
	clearingType : one ClearingType,
	managementInterfaceId : set ManagementInterfaceId,
}

sig ProbableCause extends Response{
	standardReference : lone StandardReference
}

sig StandardReference {}

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~PREDICATES~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	query_inbox' = query_inbox
	response_inbox' = response_inbox
	consumerSubscriptionId' = consumerSubscriptionId
}

pred act {
	some q : Query | send_query[q] or process_query[q]
}

pred send_query [q : Query] {
	query_inbox' = query_inbox + IMS->q
	response_inbox' = response_inbox
	consumerSubscriptionId' = consumerSubscriptionId
}

pred process_query [q : Query] {

	 q in IMS.query_inbox //guard

	query_inbox' = query_inbox - IMS->q

	q in ValidQueries.supported implies
		(get_type_list[q]
		or get_type[q]
		or get_pool_list[q]
		or get_pool[q]
		or get_resource_list[q]
		or get_resource[q]
		or get_dm_list[q]
		or get_dm[q]
		or get_cloud[q]
		or get_is_list[q]
		or get_is[q]
		or post_is[q]	
		or delete_is[q]
		or get_ad_list[q]
		or get_ad[q]
		)
	else (
		invalid_method
	)
}

pred get_type_list [q: Query] {

	q.body= GET->Type->Null //guard

	response_inbox' = response_inbox + SMO->GET_ResourceTypeList

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_type [q : Query] {

	q.body in GET->Type->Identifier // guard

	response_inbox' = response_inbox + SMO->GET_ResourceType[extract_id[q]]

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_pool_list [q: Query] {

	q.body= GET->Pool->Null //guard

	response_inbox' = response_inbox + SMO->GET_ResourcePoolList

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_pool [q : Query] {

	q.body in GET->Pool->Identifier and no q.extension // guard

	response_inbox' = response_inbox + SMO->GET_ResourcePool[extract_id[q]]

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_resource_list [q : Query] {

	q.body in GET->Pool->Identifier and q.extension in Resource->Null // guard

	response_inbox' = response_inbox + SMO->GET_ResourceList[extract_id[q]]

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_resource [q : Query] {

	q.body in GET->Pool->Identifier and q.extension in Resource->Identifier // guard

	response_inbox' = response_inbox + SMO->GET_Resource[extract_id[q], extract_extension_id[q]]

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_dm_list [q: Query] {

	q.body= GET->DeploymentManager->Null //guard

	response_inbox' = response_inbox + SMO->GET_DMList

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_dm [q : Query] {

	q.body in GET->DeploymentManager->Identifier // guard

	response_inbox' = response_inbox + SMO->GET_DM[extract_id[q]]

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_cloud [q : Query] {

	q.body in GET->oCloud->Null // guard

	response_inbox' = response_inbox + SMO->GET_Cloud

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_is_list [q: Query] {

	q.body= GET->InventorySubscription->Null //guard

	response_inbox' = response_inbox + SMO->GET_ISList

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_is [q : Query] {

	q.body in GET->InventorySubscription->Identifier // guard

	response_inbox' = response_inbox + SMO->GET_IS[extract_id[q]]

	consumerSubscriptionId' = consumerSubscriptionId
}

pred post_is [q : Query] {

	q.body in POST->InventorySubscription->Identifier //guard

	some is : InventorySubscriptionInfo | is.subscriptionId = extract_id[q] and no is.consumerSubscriptionId implies
			consumerSubscriptionId' = consumerSubscriptionId + is->SMO.consumerId and
			response_inbox' = response_inbox + SMO->is->_201_CREATED
	else
		consumerSubscriptionId' = consumerSubscriptionId and
		some pd : ProblemDetails | pd.status = _404_NOT_FOUND and response_inbox' = response_inbox + SMO->pd->_404_NOT_FOUND

}

pred delete_is [q : Query] {
	q.body in DELETE->InventorySubscription->Identifier //guard

	some is : InventorySubscriptionInfo | is.subscriptionId = extract_id[q] and some is.consumerSubscriptionId implies
		consumerSubscriptionId' = consumerSubscriptionId - is->SMO.consumerId and
		response_inbox' = response_inbox + SMO->is->_204_DELETED
	else
		consumerSubscriptionId' = consumerSubscriptionId and
		some pd : ProblemDetails | pd.status = _404_NOT_FOUND and response_inbox' = response_inbox + SMO->pd->_404_NOT_FOUND
}

pred get_ad_list [q : Query] {
	q.body in GET->AlarmDic->Null //guard

	response_inbox' = response_inbox + SMO->GET_AlarmDictionaryList

	consumerSubscriptionId' = consumerSubscriptionId
}

pred get_ad [q : Query] {
	q.body in GET->AlarmDic->Identifier //guard

	response_inbox' = response_inbox + SMO->GET_AlarmDictionary[extract_id[q]]

	consumerSubscriptionId' = consumerSubscriptionId
}

pred invalid_method  {
	some pd : ProblemDetails |
		pd.status = _405_METHOD_NOT_ALLOWED and response_inbox' = response_inbox + SMO->pd->_405_METHOD_NOT_ALLOWED

	consumerSubscriptionId' = consumerSubscriptionId
}


pred clear_response_inbox {
	response_inbox' = response_inbox - response_inbox
	query_inbox' = query_inbox

	consumerSubscriptionId' = consumerSubscriptionId
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~FACTS~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact stutter_or_act {
	always (stutter or act)
}

fact resource_cannot_point_to_itself {
	all r_info : ResourceInfo | 
		r_info not in r_info.^elements
}

fact load_valid_queries {
	all q : Query | 
		((q.body in GET->Type->Id and no q.extension) or 
		q.body in GET->Pool->Identifier or 
		(q.body in GET->Pool->Null and no q.extension) or 
		(q.body in GET->DeploymentManager->Id and no q.extension) or
		(q.body in GET->oCloud->Null and no q.extension) or
		(q.body in GET->InventorySubscription->Id and no q.extension) or
		(q.body in POST->InventorySubscription->Identifier and no q.extension) or 
		(q.body in DELETE->InventorySubscription->Identifier and no q.extension) or
		(q.body in GET->AlarmDic->Id and no q.extension)
		)implies 
			q in ValidQueries.supported
		else 	
			q not in ValidQueries.supported
}

// Used to test new funcitonallity (Delete)
fact test {
	some q : Query | q.body in GET->AlarmDic->Null
}

fact identifiers_must_be_unique {
	all disj a, b : ResourceTypeInfo | a.resourceTypeId != b.resourceTypeId
	all disj a, b : ResourcePoolInfo | a.resourcePoolId != b.resourcePoolId
	all disj a, b : ResourceInfo | a.resourceId != b.resourceId
	all disj a,b : DeploymentManagerInfo | a.deploymentManagerId != b.deploymentManagerId
	all disj a,b  : InventorySubscriptionInfo | a.subscriptionId != b.subscriptionId 
	all disj a,b : AlarmDictionary | a.alarmDictionaryId != b.alarmDictionaryId
}

fact ids_link_to_resources {
	all r : ResourceInfo | r.resourcePoolId in ResourcePoolInfo.resourcePoolId and r.resourceTypeId in ResourceTypeInfo.resourceTypeId
	all dm : DeploymentManagerInfo | dm.oCloudid in OCloudInfo.oCloud
}

fact query_one_payload {
	all q : Query | one q.body and lone q.extension
}

fact init {
	no IMS.query_inbox and no SMO.response_inbox
	all is : InventorySubscriptionInfo | no is.consumerSubscriptionId
}

// *temporary*
fact exists_valid_query {
	some ValidQueries.supported
}

fact ProblemDetails_generator {
	all rc : ResponseCode | some pd : ProblemDetails | pd.status = rc
}

fact queries_must_be_processed {
	all q : Query | send_query[q] implies process_query[q]
}

fact all_queries_at_least_once {
	eventually (all q : Query | send_query[q])
}

fact disj_queries {
	all disj a,b : Query | a.body != b.body
}
	
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~FUNCTIONS (HTTP Queries)~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~	


// extract id from query body 
fun extract_id [q : Query] : one Identifier {
	{id : Identifier | q.body in HTTP->ResponseType->id}
}

// extract id from query extension
fun extract_extension_id [q: Query] : one Identifier {
	{id : Identifier| q.extension in Resource->id}
}


// Get the list of all resource types
fun GET_ResourceTypeList : set Response -> ResponseCode {	
	{ResourceTypeInfo} -> _200_OK
}


// Get a type given its id
fun GET_ResourceType [id : Identifier] : set Response -> ResponseCode {	
	
	(id in ResourceTypeInfo.resourceTypeId) implies
		{rt : ResourceTypeInfo | rt.resourceTypeId = id} -> _200_OK
	else 
		{pd : ProblemDetails | pd.status = _404_NOT_FOUND} -> _404_NOT_FOUND
}


// Get the list of all pools
fun GET_ResourcePoolList : set Response -> ResponseCode {	
	{ResourcePoolInfo} -> _200_OK
}


// Get the info a pool given its id
fun GET_ResourcePool [id : Identifier] : set Response -> ResponseCode {	
	
	(id in ResourcePoolInfo.resourcePoolId) implies
		{rp : ResourcePoolInfo | rp.resourcePoolId = id} -> _200_OK
	else 
		{pd : ProblemDetails | pd.status = _404_NOT_FOUND} -> _404_NOT_FOUND
}


// Get the list of resources in a given pool
fun GET_ResourceList [pool_id : Identifier] : set Response -> ResponseCode {	

	(pool_id in ResourcePoolInfo.resourcePoolId) implies
		{r : ResourceInfo | r.resourcePoolId = pool_id} -> _200_OK
	else 
		{pd : ProblemDetails | pd.status = _404_NOT_FOUND} -> _404_NOT_FOUND
}


// Get a resource given its id and the pool its located in
fun GET_Resource [pool_id : Identifier, id : Identifier] : set Response -> ResponseCode {	
	
	(some r : ResourceInfo | r.resourcePoolId = pool_id and r.resourceId = id) implies
		{r : ResourceInfo | r.resourcePoolId = pool_id and r.resourceId = id} -> _200_OK
	else 
		{pd : ProblemDetails | pd.status = _404_NOT_FOUND} -> _404_NOT_FOUND
}


// Get the list of all deployment managers
fun GET_DMList : set Response -> ResponseCode {	
	{DeploymentManagerInfo} -> _200_OK
}

// Get a deployment manager given its id
fun GET_DM [id : Identifier] : set Response -> ResponseCode {	
	
	(id in DeploymentManagerInfo.deploymentManagerId) implies
		{dm : DeploymentManagerInfo | dm.deploymentManagerId = id} -> _200_OK
	else 
		{pd : ProblemDetails | pd.status = _404_NOT_FOUND} -> _404_NOT_FOUND

}

// Get the O-Cloud
fun GET_Cloud : set Response -> ResponseCode {	
	{OCloudInfo} -> _200_OK
}

// Get the list of all subscriptions
fun GET_ISList : set Response -> ResponseCode {	
	{InventorySubscriptionInfo} -> _200_OK
}

// Get a subscription given its id
fun GET_IS [id : Identifier] : set Response -> ResponseCode {	
	
	(id in InventorySubscriptionInfo.subscriptionId) implies
		{is : InventorySubscriptionInfo | is.subscriptionId = id} -> _200_OK
	else 
		{pd : ProblemDetails | pd.status = _404_NOT_FOUND} -> _404_NOT_FOUND
}

// Get list of all AlarmDictionaries
fun GET_AlarmDictionaryList : set Response -> ResponseCode {
	{AlarmDictionary} -> _200_OK
}

// Get a specific AlarmDictionary
fun GET_AlarmDictionary [id : Identifier] : set Response -> ResponseCode {
	(id in AlarmDictionary.alarmDictionaryId) implies 
		{ad :AlarmDictionary | ad.alarmDictionaryId = id } ->_200_OK
	else
		{pd : ProblemDetails | pd.status = _404_NOT_FOUND} -> _404_NOT_FOUND
}

