}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// If the SMO recieves a response, then in all previous states, there has been some deployed NF.
// Valid assertion implies that there exists no traces were a creation request is handled but there was initially no deployed NFs. 
// A system in which no NFs are deployed is a valid one. Hence this reveals a problem
assert blah {
	always (some SMO.response implies historically some oCloud.deployed)
}

// If initially there are no NFs in deployment, then even though pre-conditions are met, a slice creation request can never be sent. 
assert blah2 {
	(no oCloud.deployed implies always no oCloud.requests)
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

check blah2 for 3 but exactly 1 oCloud, exactly 2 NF, exactly 2 VLAN_ID, exactly 1 Slice, 20 steps
check blah for 3 but exactly 1 oCloud, exactly 2 NF, exactly 2 VLAN_ID, exactly 1 Slice, 20 steps

run {} for 3 but exactly 2 oCloud, exactly 3 NF, exactly 2 VLAN_ID, exactly 2 Slice, 20 steps

