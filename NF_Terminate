sig oCloud {
	dms : one DMS,
	var nodes : set Node,
	var pool : set Resource
}
	
sig DMS {
	cloud : one oCloud,
	var requests : set Request
}

one sig SMO {
	var responses: set Request->Response
}

sig Node {
	var deployment : set NF
}

sig NF {
	var resources : set Resource
}

sig Resource {}

sig Request {
	target : one oCloud,
	payload : one NF,
	var processed : lone Response
}

enum Response {
	SUCCESS, 
	ERROR
}


//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	deployment' = deployment 
	nodes' = nodes
	requests' = requests
	responses' = responses
	resources' = resources
	pool' = pool
	processed' = processed
}

pred act {
	some r : Request, c : oCloud | initiate_termination[r] or finish_termination[r,c] or send_response[r,c]
}


// If a request is present, we assume that all precondtions are met and the request is sent to the appropriate DMS.
pred initiate_termination [r : Request] {
	
	r.payload in Node.deployment and r not in DMS.requests//guard

	requests' = requests + r.target.dms->r

	deployment' = deployment 	
	nodes' = nodes
	responses' = responses
	resources' = resources
	pool' = pool
	processed' = processed
}


// Finish deployment, delete request, send appropriate response.
pred finish_termination [r : Request, c : oCloud] {

	r in c.dms.requests and no r.processed//guard

	(r.payload in c.nodes.deployment) implies (
		some node : Node | r.payload in node.deployment and 
			deployment' = deployment - node->r.payload and 
			processed' = processed+ r->SUCCESS and
			pool' = pool + r.target->r.payload.resources and
			resources' = resources - r.payload->r.payload.resources

	)else(
		deployment' = deployment and
		processed' = processed + r->ERROR and
		pool'= pool and
		resources' = resources
	)	

	requests' = requests
	nodes' = nodes
	responses' = responses
}

pred send_response [r : Request, c : oCloud] {

	r in c.dms.requests and some r.processed//guard

	requests' = requests - c.dms->r
	responses' = responses + SMO->r->r.processed
	processed' = processed - r->r.processed

	deployment' = deployment 
	nodes' = nodes
	resources' = resources
	pool' = pool
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact act_or_stutter {
	always (stutter or act)
}

fact disj_NF {
	all disj a,b : Request | a.payload != b.payload
}

fact init {
	no DMS.requests
	no (oCloud.pool & NF.resources)
	no Request.processed
	some oCloud.pool
	some NF.resources
	some oCloud.nodes
	some Node.deployment
	no SMO.responses
	all d : DMS | no d.requests
	all node : Node | some node.deployment implies node in oCloud.nodes
	all nf : NF | some nf.resources implies nf in Node.deployment
	all disj a,b : Node | no (a.deployment & b.deployment)
	all disj a,b : oCloud | no (a.pool & b.pool)
	all nf : NF | nf not in Node.deployment implies no nf.resources
}

fact unique_cloud_properties {
	all disj a,b : oCloud | a.dms != b.dms
}

fact link_managenodes_with_correct_cloud {
	all d : DMS, c : oCloud | d.cloud = c <=> c.dms = d
}

fact fairness {
//	eventually (some r : Request | r->ERROR in SMO.responses)
//	all r : Request | eventually (before r in DMS.requests and r not in DMS.requests)
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// (1) safety
assert fail_case_ends_in_error_message {
	always (all r : Request | (r in r.target.dms.requests and r.processed = ERROR and r.payload not in r.target.nodes.deployment) implies eventually r->ERROR in SMO.responses)
}

// (2) safety
assert success_case_ends_in_success_message {
	always (all r : Request | (r in r.target.dms.requests and r.payload in r.target.nodes.deployment) implies eventually r->SUCCESS in SMO.responses)
}

// (3) safety
assert fail_case_ends_in_no_removal {
	always (all r : Request | (r in r.target.dms.requests and no r.processed and r.payload not in r.target.nodes.deployment) implies eventually r.payload in Node.deployment)
}

// (4) safety
assert success_case_ends_in_removal {
	always (all r : Request | (r in r.target.dms.requests and r.payload in r.target.nodes.deployment) implies eventually r.payload not in Node.deployment)
}

// (5) safety
assert processed_request_implies_response {
	always (some r : Request | before r in DMS.requests and r not in DMS.requests implies eventually r->SUCCESS in SMO.responses or r->ERROR in SMO.responses)
}

// (6) safety
assert termination_implies_resource_deallocation {
	always (some r : Request | (r.processed = SUCCESS) => no r.payload.resources and {re : Resource | before re in r.payload.resources} in oCloud.pool)
}

// (7) safety
assert request_never_sent_if_NF_not_deployed {
	always (some r : Request | before r not in DMS.requests and r in DMS.requests implies r.payload in Node.deployment)
}

// (8) safety
assert processed_state_matches_response {
	always (all r : Request | r.processed = ERROR implies eventually r->ERROR in SMO.responses)
	always (all r : Request | r.processed = SUCCESS implies eventually r->SUCCESS in SMO.responses)
}

// (9) Safety
assert not_deployed_implies_no_resoures {
	always (all nf : NF | nf not in Node.deployment => no nf.resources)
}

// (10) Safety
assert success_implies_resource_deallocation {
	always (all r : Request | r->SUCCESS in SMO.responses implies no r.payload.resources)
}

// (11) safety
assert response_implies_nf_correct_nf_state {
	always (all r:Request | r->SUCCESS in SMO.responses implies r.payload not in Node.deployment)
	always (all r:Request | r->ERROR in SMO.responses implies r.payload in Node.deployment)
}

// (12) safety 
assert disjoint_nfs {
	always (all disj a,b : Node | no (a.deployment & b.deployment))
}

// (13) liveness
assert failure {
	always (all r : Request | r->ERROR not in SMO.responses)
}

