sig oCloud {
	dms : one DMS,
	nodes : set oCloudNode,
	var pool : set Resource
}

enum Operation {
	IN,
	OUT
}

enum Response {
	OK,
	ERROR,
	ROLLBACK
}

sig Resource {}

	
sig DMS {
	cloud : one oCloud,
	var requests : set Request
}

sig Request {
	operation : one Operation,
	target : one oCloud,
	payload : one NF,
	var status : lone Response
}

one sig SMO {
	var response_inbox : set Request->Response
}

sig oCloudNode {
	var deployment : set NF
}

sig NF {
	var resources: set Resource
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	deployment' = deployment 
	requests' = requests
	response_inbox' = response_inbox
	resources' = resources
	pool' = pool
	status' = status
}


pred act {
	some r : Request |
				     initiate[r] or
			             finish_scale_out[r] or
				     finish_scale_in[r] or
				    smo_response[r]
}


// Send a scaling request to DMS
pred initiate [r : Request] {

	 historically r not in r.target.dms.requests and r.payload in r.target.nodes.deployment//guard

	requests' = requests + r.target.dms->r

	deployment' = deployment 
	response_inbox' = response_inbox
	resources' = resources
	pool' = pool
	status' = status
	
}

// Attempt scale out
pred finish_scale_out[r : Request] {
	
	r.operation = OUT and r in r.target.dms.requests and no r.status//guard

	(some r.target.pool) implies(
		some resource : Resource | resource in r.target.pool and
							   resources' = resources + r.payload->resource and
							   pool' = pool - r.target->resource and
							   status' = status + r->OK
	)
	else(
		resources' = resources and
		pool' = pool and
		status' = status + r->ERROR
	)
		
	response_inbox' = response_inbox
	deployment' = deployment
	requests' = requests
}


// Attempt Scale In
pred finish_scale_in[r : Request] {
	
	r.operation = IN and r in r.target.dms.requests and no r.status//guard

	(some r.payload.resources) implies(
		some resource : Resource | resource in r.payload.resources and 
							  resources' = resources - r.payload->resource and
							  pool' = pool + r.target->resource and
							  status' = status + r->OK
	)
	else(
		resources' = resources and
		pool' = pool and 
		status' = status + r->ERROR
	)

	response_inbox' = response_inbox
	deployment' = deployment
	requests' = requests
}


// Send appropriate response to SMO based upon success of operation
pred smo_response [r : Request]{

	r in r.target.dms.requests and some r.status//guard

	requests' = requests - r.target.dms->r
	response_inbox' = response_inbox + SMO->r->r.status
	status' = status - r->r.status

	deployment' = deployment 
	resources' = resources
	pool' = pool
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact act_or_stutter {
	always (act or stutter)
}

fact init {	
	all nf : NF | some r : Request | r.payload = nf
	all r : Request | no r.status
	some Resource
	some Request
	all r : Resource | r in oCloud.pool
	all node : oCloudNode | node in oCloud.nodes
	all nf : NF | nf in oCloudNode.deployment and no nf.resources
	no SMO.response_inbox
	all d : DMS | no d.requests
	all disj a,b : oCloud | no (a.nodes & b.nodes) and no (a.pool & b.pool)
}

fact unique_cloud_properties {
	all disj a,b : oCloud | a.dms != b.dms
}

fact link_managers_with_correct_cloud {
	all d : DMS, c : oCloud | d.cloud = c <=> c.dms = d
}	

// All requests must result in SMO response
fact fairness {
	eventually (all r : Request | r->OK in SMO.response_inbox or r->ERROR in SMO.response_inbox)
}

// Show error and SMO response are compatible
//fact error_allows_progression {
//	eventually (some r : Request | (before ERROR in r.status) and r->ERROR in SMO.response_inbox)
//}

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// (Safety) Processed Requets imply present response
assert processed_request_yields_response {
	always (all r : Request | (before r in DMS.requests and r not in DMS.requests) implies (r->OK in SMO.response_inbox or r->ERROR in SMO.response_inbox))
}

// (Safety) Under the assumption that an allocated resource cannot be allocated to another NF Deployment
assert disjoint_resources {
	always (all disj a,b : NF | no (a.resources & b.resources))
}

// (Liveness) we would expect that a deallocated node should be able to be reallocated later.
assert deallocateed_never_reallocated {
	always (all r : Resource | once (before r in NF.resources and r not in NF.resources) implies (r in oCloud.pool))
}

// (Safety) Correct repsonse is posted to SMO
assert correct_responses {
	always (all r : Request | ((before ERROR in r.status and ERROR not in r.status) implies r->ERROR in SMO.response_inbox) and 
		  ((before OK in r.status and OK not in r.status) implies r->OK in SMO.response_inbox))
}

