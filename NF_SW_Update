sig oCloud {
	dms : one DMS,
	nodes : set oCloudNode,
	var pool : set Resource
}

enum Response {
	OK,
	ERROR
}

enum Operation {
	ADD,
	DELETE
}

sig Resource {}

	
sig DMS {
	cloud : one oCloud,
	var requests : set Request
}

sig Request {
	operation : one Operation,
	target : one oCloud,
	payload : one NF
}

sig UpdateRequest {
	existing: one NF,
	desired: one NF,
	var status : lone Response
}

one sig SMO {
	var update_request : set UpdateRequest,
	var response_inbox : set Request->Response
}

sig oCloudNode {
	var deployment : set NF
}

sig NF {
	var resources: set Resource
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	deployment' = deployment 
	requests' = requests
	response_inbox' = response_inbox
	resources' = resources
	pool' = pool
	update_request' = update_request 
	status' = status
}

pred act {
	(some r : UpdateRequest |
		initiate_update[r] or
		deploy_update[r] or
		sim_update[r] or
		evaluate_update[r]
	)or(
	some re : Request |
		finish_deployment[re] or
		finish_termination[re]
	)
}

pred finish_deployment [r : Request] {

	r in r.target.dms.requests and r.operation = ADD//guard

	requests' = requests - r.target.dms->r
	
	some node : oCloudNode | node in r.target.nodes and deployment' = deployment + node->r.payload and response_inbox' = response_inbox + SMO->r->OK

	resources' = resources
	pool' = pool
	update_request' = update_request 
	status' = status

}

pred finish_termination [r : Request] {

	r in r.target.dms.requests and r.operation = DELETE//guard

	requests'= requests - r.target.dms->r

	pool' = pool + r.target->r.payload.resources  
	resources' = resources - r.payload->r.payload.resources
	some node : oCloudNode |(r.payload in node.deployment and deployment' = deployment - node->r.payload) 
	response_inbox' = response_inbox + SMO->r->OK

	update_request' = update_request 
	status' = status

}

pred initiate_update [r : UpdateRequest] {

	r not in SMO.update_request and r.existing in oCloudNode.deployment and r.desired not in oCloudNode.deployment//guard

	update_request'  = update_request  + SMO->r

	deployment' = deployment 
	requests' = requests
	response_inbox' = response_inbox
	resources' = resources
	pool' = pool
	status' = status

}

pred deploy_update [r : UpdateRequest] {
	
	r in SMO.update_request and (some re : Request | re.payload = r.desired and re.operation = ADD and re not in DMS.requests) and r.desired not in oCloudNode.deployment//guard
	
	some r_add : Request, c : oCloud | r_add.operation = ADD and r.existing in c.nodes.deployment and r_add.target = c and r_add.payload = r.desired and requests' = requests + r_add.target.dms->r_add

	deployment' = deployment 
	response_inbox' = response_inbox
	resources' = resources
	pool' = pool
	update_request' = update_request 
	status' = status
}

pred sim_update [r : UpdateRequest] {

	r in SMO.update_request and r.desired in oCloudNode.deployment and no r.status//guard

	status' = status + r->OK or 
	status' = status + r->ERROR
	
	deployment' = deployment 
	requests' = requests
	response_inbox' = response_inbox
	resources' = resources
	pool' = pool
	update_request' = update_request 
}

pred evaluate_update [r : UpdateRequest] {
	
	 r in SMO.update_request and some r.status //guard

	(r.status = OK) implies(
		(some r_term : Request, c : oCloud | r_term.operation = DELETE and r.existing in c.nodes.deployment and r_term.payload = r.existing and r_term.target = c and requests' = requests + c.dms->r_term)
		and status' = status - r->OK
	)
	else(
		(some r_term : Request, c : oCloud | r_term.operation = DELETE and r.desired in c.nodes.deployment and r_term.target = c and r_term.payload = r.desired and requests' = requests + c.dms->r_term)
		and status' = status - r->ERROR
	)

	update_request' = update_request - SMO->r

	deployment' = deployment 
	response_inbox' = response_inbox
	resources' = resources
	pool' = pool

}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact act_or_stutter {
	always (act or stutter)
}

fact init {	
//	all nf : NF | some r : Request | r.payload = nf
	all r : Resource | r in oCloud.pool or r in NF.resources
	no (oCloud.pool & NF.resources)
	all node : oCloudNode | node in oCloud.nodes
	no SMO.response_inbox and no SMO.update_request
	all r : UpdateRequest | no r.status and (r.existing != r.desired) and r.desired not in oCloudNode.deployment and r.existing in oCloudNode.deployment
	all d : DMS | no d.requests
	some UpdateRequest
	some oCloudNode.deployment
	all disj a,b : oCloud | no (a.nodes & b.nodes) and no (a.pool & b.pool)
	all nf : NF | nf not in oCloudNode.deployment implies no nf.resources
	all disj a,b : oCloudNode | no(a.deployment & b.deployment)
	all disj a,b : Request | a.operation = b.operation and a.target = b.target implies a.payload != b.payload
	all disj a,b : UpdateRequest | a.existing != b.existing and a.desired != b.desired and a.desired != b.existing and a.existing != b.desired
}

fact unique_cloud_properties {
	all disj a,b : oCloud | a.dms != b.dms
}

fact link_managers_with_correct_cloud {
	all d : DMS, c : oCloud | d.cloud = c <=> c.dms = d
}	


// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

//safety
assert update_request_processed_implies_termination {
	always (all r : UpdateRequest | (before r in SMO.update_request and r not in SMO.update_request) implies some re : Request | re in DMS.requests and (re.payload = r.existing or re.payload = r.desired) and re.operation = DELETE)
}

//safety
assert requests_sent_to_the_correct_place {
	always (all r : Request | r in r.target.dms.requests and r.operation = DELETE implies r.payload in r.target.nodes.deployment)
	always (all r : Request | r in r.target.dms.requests and r.operation = ADD implies r.payload not in r.target.nodes.deployment)
}

//safety
assert process_requests_imply_response {
	always (all r : Request | (before r in DMS.requests and r not in DMS.requests) implies (r->OK in SMO.response_inbox or r->ERROR in SMO.response_inbox))
}

//safety
assert only_one_NF_remains {
	always (all r : UpdateRequest | (once r.desired in oCloudNode.deployment and r.desired not in oCloudNode.deployment and r.existing in oCloudNode.deployment) implies once r.status = ERROR)
	always (all r : UpdateRequest | (r.existing not in oCloudNode.deployment and r.desired in oCloudNode.deployment) implies once r.status = OK)
}

//safety
assert update_idea_implies_conditions_for_update {
	always (all r : UpdateRequest | (before r not in SMO.update_request and r in SMO.update_request) implies r.desired not in oCloudNode.deployment and r.existing in oCloudNode.deployment)
}	

//safety
assert terminated_NF_imply_deallocated_resources {
	always (all nf : NF | (before nf in oCloudNode.deployment and nf not in oCloudNode.deployment) implies no nf.resources and {resource : Resource| before resource in nf.resources} in oCloud.pool)
}

//liveness
assert success {
	always (all ur : UpdateRequest | ur.status != OK)
}

//liveness
assert failure {
	always (all ur : UpdateRequest | ur.status != ERROR)	
}

//liveness
assert desired_and_exisitng_on_same_node {
	always (all disj a,b : NF | some ur : UpdateRequest | a in ur.desired and b in ur.existing and (a+b) in oCloudNode.deployment implies some node : oCloudNode | a in node.deployment and b in node.deployment)
}

// safety
assert desired_and_exisiting_same_oCloud {
	always (all ur : UpdateRequest | (ur.desired + ur.existing) in oCloudNode.deployment implies some c :oCloud | (ur.desired + ur.existing) in c.nodes.deployment)
}

// safety
assert responses_imply_corresponding_action {
	always (all r : Request | r->OK in SMO.response_inbox and r.operation = ADD implies once(r.payload in oCloudNode.deployment))
	always (all r : Request | r->OK in SMO.response_inbox and r.operation = DELETE implies once(r.payload not in oCloudNode.deployment))
}

assert update_request_status_implies_both_deployed {
	always (all ur : UpdateRequest | some ur.status implies (ur.desired + ur.existing) in oCloudNode.deployment)
}

// ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

check desired_and_exisiting_same_oCloud
