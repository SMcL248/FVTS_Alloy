//Safety - If a slice is deployed, but NF deployments are missing, this must be due to an on-going deletion request
assert partial_slices {
	always (all s : Slice | (some c : oCloud, id : VLAN_ID | c->id in s.ids and some {nf : NF | nf in s.nfs and nf not in oCloud.deployed} implies s in c.requests))
}

// Safety
assert available_id_implies_no_nf_with_id {
	always (all id : VLAN_ID | some c : oCloud | id in c.available implies no {nf : NF | nf in c.deployed and id in nf.trunk} )
}

// livness - success can happen
assert success{
	always (all s : Slice | s->OK not in SMO.response)
}

//livess
assert failure {
	always (all s : Slice | s->ERROR not in SMO.response)
}


assert delete_request_implies_delete {
	always (all s : Slice | s in oCloud.requests implies eventually {nf : NF | nf in s.delete} not in oCloud.deployed and {nf : NF | nf in (s.nfs - s.delete)} in oCloud.deployed )
}
assert delete_implies_ID_deallocation {
	always (all s : Slice | some c : oCloud | s in c.requests implies eventually {id : VLAN_ID | c->id in s.ids} in c.available and {id : VLAN_ID | c->id in s.ids} not in {nf : NF | nf in c.deployed}.trunk)
}
assert request_implies_response{
	always(all s : Slice | s in oCloud.requests implies eventually s->OK in SMO.response or s->ERROR in SMO.response)
}



