sig oCloud {
	var available : set VLAN_ID,
	var requests : set Slice,
	var deployed : set NF,
	hardware : lone Node
}

sig Slice {
	var ids : set oCloud->VLAN_ID,
	nfs : set NF,
	delete : set NF,
	var status : lone Response
}

sig Node {}

sig NF {
	var trunk : set VLAN_ID
}

enum Operation {
	ALLOCATE,
	DEALLOCATE
}

enum Response {
	OK, 
	ERROR
}

sig VLAN_ID {}

one sig SMO {
	var response: set Slice->Response
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

pred stutter {
	available' = available 
	requests' = requests
	ids' = ids
	response' = response
	trunk' = trunk
	deployed' = deployed
	status' = status
}

pred act {
	some s : Slice, c : oCloud, id: VLAN_ID | send_request[s] or term_nf[s,c,id]  or deallocate[s,c,id] or evaluate_slice_destroy[s] or sim_failure[s]
}

// Start deletion
pred send_request [s : Slice] {

	s not in oCloud.requests//guard

	requests' = requests + {cl : oCloud | (some id : VLAN_ID | cl->id in s.ids)}->s

	ids' = ids
	available' = available
	response' = response
	trunk' = trunk
	deployed' = deployed
	status' = status

}

// Terminate NFs as required
pred term_nf [s : Slice, c : oCloud, id : VLAN_ID]{

	s in c.requests and c->id in s.ids and (some nf : NF | nf in s.delete and nf in c.deployed and id in nf.trunk)//guard

	trunk' = trunk - {nf : NF | nf in s.delete and nf in c.deployed and id in nf.trunk}->id
	deployed' = deployed - c->{nf : NF | nf in s.delete and nf in c.deployed}

	available' = available 
	requests' = requests
	ids' = ids
	response' = response
	status' = status

}
	
// Remove VLAN ID from all NF that were not terminated and make VLAN ID available
pred deallocate [s : Slice, c : oCloud, id : VLAN_ID] {

	s in c.requests and c->id in s.ids and no (s.delete & c.deployed)//guard

	trunk' = trunk - {nf : NF | nf in (s.nfs - s.delete) and id in nf.trunk}->id	
	available' = available + c->id

	deployed' = deployed
	requests' = requests
	response' = response
	ids' = ids
	status' = status
}

pred sim_failure [s : Slice] {

	s in oCloud.requests//guard
	
	status' = status + s->ERROR

	available' = available 
	requests' = requests
	ids' = ids
	response' = response
	trunk' = trunk
	deployed' = deployed

}

// Once NFs are terminated and all VLAN-ID are deallocated, send response
pred evaluate_slice_destroy [s : Slice] {

	s in oCloud.requests and ((no {id : VLAN_ID | (some c : oCloud, nf : NF | c->id in s.ids and nf in c.deployed and id in nf.trunk)} and no {id : VLAN_ID | some c : oCloud | c->id in s.ids and id not in c.available}) or some s.status)//guard

	(s.status = ERROR) implies (
		requests' = requests - {c : oCloud | s in c.requests}->s and
		response' = response + SMO->s->ERROR and
		ids' = ids 
	)else(
		requests' = requests - {c : oCloud | s in c.requests}->s and
		response' = response + SMO->s->OK and
		ids' = ids - s->s.ids
	)

	available' = available 
	trunk' = trunk
	deployed' = deployed
	status' = status
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fun extract_id [s : Slice, c : oCloud] : one VLAN_ID{
	{id : VLAN_ID | c->id in s.ids}
}

//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

fact act_or_stutter {
	always (act or stutter)
}

fact delete_subset_nf {
	always (all s : Slice | s.delete in s.nfs)
}	

fact no_shared_hardware {
	all disj a,b : oCloud | no (a.hardware & b.hardware)
}

fact no_shared_locations {
	all disj a,b : Slice | no (a.ids & b.ids)
}

fact init {
	all nf : NF | some nf.trunk
	all nf : NF | some nf.trunk implies nf in Slice.nfs
	all s : Slice, c : oCloud| lone {id : VLAN_ID| c->id in s.ids}
//	all s : Slice, nf : NF | nf in s.nfs implies (some c : oCloud, id : VLAN_ID | nf in c.deployed and id in nf.trunk and c->id in s.ids)
//	all id : VLAN_ID | (all nf : NF | id in nf.trunk implies (some s : Slice, c : oCloud| nf in c.deployed and c->id in s.ids))
	all nf : NF | nf not in oCloud.deployed implies no nf.trunk and nf not in Slice.nfs
//	all disj a,b : NF | (some c : oCloud, s : Slice | (a in c.deployed and b in c.deployed) and (a in s.nfs and b in s.nfs) implies (a.trunk = b.trunk))
//	all id : VLAN_ID | (all nf : NF, c : oCloud | (id in nf.trunk and nf in c.deployed) implies id not in c.available)
	all id : VLAN_ID | (some c :oCloud, s : Slice | c->id in s.ids implies id not in c.available)
	all c : oCloud | no c.requests and some c.hardware and some c.deployed
	no SMO.response
	all s : Slice | some s.ids and some s.nfs and some s.delete and no s.status
//	all nf : NF | some id : VLAN_ID, s : Slice, c : oCloud | id in nf.trunk and nf in c.deployed implies c->id in s.ids and nf in s.nfs
	all nf : NF, id : VLAN_ID, c : oCloud | id in nf.trunk and nf in c.deployed <=> some s : Slice | c->id in s.ids and nf in s.nfs
	all id : VLAN_ID, c : oCloud, nf : NF | id in nf.trunk and nf in c.deployed => id not in c.available
}

